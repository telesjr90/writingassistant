{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "writer_questions.schema.json",
  "title": "Writer Questions Output",
  "description": "Diagnostic questions that help the writer inspect structure without generating prose.",
  "type": "object",
  "required": [
    "task",
    "questions",
    "no_prose_generated"
  ],
  "properties": {
    "task": {
      "const": "writer_questions"
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "throughline",
          "story_point",
          "diagnostic_purpose",
          "question"
        ],
        "properties": {
          "throughline": {
            "type": "string",
            "enum": [
              "overall_story",
              "main_character",
              "influence_character",
              "relationship_story",
              "mixed",
              "insufficient_evidence"
            ]
          },
          "story_point": {
            "type": "string",
            "minLength": 1
          },
          "diagnostic_purpose": {
            "type": "string",
            "minLength": 1
          },
          "question": {
            "description": "An open-ended diagnostic question, never replacement prose or a proposed line.",
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "no_prose_generated": {
      "const": true
    }
  },
  "additionalProperties": false
}
